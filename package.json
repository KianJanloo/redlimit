{
  "name": "redlimit",
  "version": "0.1.0",
  "description": "Redis-backed rate limiter for Node.js with sliding-window and token-bucket algorithms. Supports Express and NestJS.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "prepare": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KianJanloo/redlimit.git"
  },
  "keywords": [
    "rate-limit",
    "rate-limiter",
    "redis",
    "express",
    "nestjs",
    "sliding-window",
    "token-bucket"
  ],
  "author": "Kian Janloo",
  "license": "MIT",
  "type": "module",
  "bugs": {
    "url": "https://github.com/KianJanloo/redlimit/issues"
  },
  "homepage": "https://github.com/KianJanloo/redlimit#readme",
  "dependencies": {
    "ioredis": "^5.11.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.1.0",
    "typescript": "^5.5.0"
  }
}